# Soroban RPC endpoint used by the Next.js app.
# Testnet: https://soroban-testnet.stellar.org
# Futurenet: https://rpc-futurenet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Deployed Soroban contract ID (starts with "C...").
# Set by scripts/deploy-contract.sh after deployment.
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Stellar network passphrase used for signing and network validation.
# Testnet: Test SDF Network ; September 2015
# Futurenet: Test SDF Future Network ; October 2022
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
